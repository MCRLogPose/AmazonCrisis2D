# This gitignore file is specifically tailored for Unity projects.
# Source: https://github.com/github/gitignore/blob/main/Unity.gitignore

/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Uu]serSettings/

# Asset store packages can be downloaded, only keep track of your own code
/[Aa]ssets/AssetStoreTools*

# Visual Studio / MonoDevelop / Rider generated files and folders
.vs/
.idea/
.gradle/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.opendb-shm
*.opendb-wal

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app
*.dll
*.exe

# Crashlytics generated file
crashlytics-build.properties

# PlasticSCM ignore file
.plastic/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
